{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/app": ["src/app"],
      "@/app/*": ["src/app/*"],
      "@/pages": ["src/pages"],
      "@/pages/*": ["src/pages/*"],
      "@/features": ["src/features"],
      "@/features/*": ["src/features/*"],
      "@/shared": ["src/shared"],
      "@/shared/*": ["src/shared/*"],
      "@/shared/components": ["src/shared/components"],
      "@/shared/components/*": ["src/shared/components/*"],
      "@/shared/ui": ["src/shared/ui"],
      "@/shared/ui/*": ["src/shared/ui/*"],
      "@/shared/lib": ["src/shared/lib"],
      "@/shared/lib/*": ["src/shared/lib/*"],
      "@/shared/theme": ["src/shared/theme"],
      "@/shared/theme/*": ["src/shared/theme/*"],
      "@/shared/i18n": ["src/shared/i18n"],
      "@/shared/i18n/*": ["src/shared/i18n/*"],
      "@/shared/providers": ["src/app/providers"],
      "@/shared/providers/*": ["src/app/providers/*"],
      "@/shared/layout": ["src/shared/layout"],
      "@/shared/layout/*": ["src/shared/layout/*"],
      "@/hooks": ["src/hooks"],
      "@/hooks/*": ["src/hooks/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
